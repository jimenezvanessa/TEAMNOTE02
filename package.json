{
  "name": "team-note",
  "version": "1.0.0",
  "description": "TeamNote monorepo app",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "vercel-build": "cd \"frontend/TeamNote mockup\" && npm install && npm run build && node ../../copy-build.js",
    "build": "cd \"frontend/TeamNote mockup\" && npm run build",
    "frontend:dev": "cd \"frontend/TeamNote mockup\" && npm run dev",
    "backend:dev": "cd backend && npm run dev",
    "start": "node backend/server.js",
    "vercel-dev": "npx vercel dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "fs-extra": "^11.2.0",
    "vercel": "latest"
  }
}
