# Single local environment file for the whole monorepo
# Copy this file to .env in repository root.

# Backend
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
JWT_SECRET=replace-with-a-strong-random-secret
FRONTEND_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# Frontend (optional for local; /api is used by default)
VITE_API_URL=/api
