{
  "version": 2,
  "buildCommand": "cd 'frontend/TeamNote mockup' && npm run build",
  "installCommand": "npm install && cd 'frontend/TeamNote mockup' && npm install",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/static/(.+)",
      "dest": "/frontend/TeamNote mockup/build/static/$1"
    },
    {
      "src": "/assets/(.+)",
      "dest": "/frontend/TeamNote mockup/build/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/TeamNote mockup/build/favicon.ico",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/index.html",
      "dest": "/frontend/TeamNote mockup/build/index.html"
    },
    {
      "src": "^/(?!api)(.*)$",
      "dest": "/frontend/TeamNote mockup/build/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/TeamNote mockup/build/index.html"
    }
  ]
}


