{
  "version": 2,
  "builds": [
    {
      "src": "frontend/TeamNote mockup/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/((?!api|_next/static|_next/image|favicon.ico|.*\\.(js|css|png|jpg|ico|svg)).*)",
      "dest": "/frontend/TeamNote mockup/build/index.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/TeamNote mockup/build/favicon.ico"
    }
  ]
}
