{
  "version": 2,
  "buildCommand": "cd 'frontend/TeamNote mockup' && npm run build",
  "installCommand": "npm install && cd 'frontend/TeamNote mockup' && npm install",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js",
      "status": 404
    },
    {
      "src": "/((?!api|_next/static|_next/image|favicon.ico|.*\\.(js|css|png|jpg|ico|svg|woff|woff2)).*)",
      "dest": "/frontend/TeamNote mockup/build/index.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/TeamNote mockup/build/favicon.ico"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret"
  }
}

